FINNHUB_API_KEY=your_finnhub_api_key_here
PUBLIC_API_SECRET=your_public_com_secret_key_here
PORT=3001

# Schwab API (https://developer.schwab.com)
SCHWAB_CLIENT_ID=your_schwab_app_key
SCHWAB_CLIENT_SECRET=your_schwab_app_secret
# Must match the Callback URL registered in your Schwab app (Schwab requires HTTPS)
SCHWAB_REDIRECT_URI=https://127.0.0.1/api/schwab/callback
# Optional: pre-seed a refresh token to skip the browser OAuth step
SCHWAB_REFRESH_TOKEN=
# Frontend origin — used to redirect back after OAuth
CLIENT_URL=http://localhost:5173
